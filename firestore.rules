rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Content — anyone authenticated can read; only admins can write
    match /content/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Profiles — users can only read/write their own profile
    match /profiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Admin collection — readable by authenticated users (for role check), not writable via client
    match /admin/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
